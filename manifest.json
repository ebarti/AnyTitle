{
  "manifest_version": 2,
  "name": "AnyTitle",
  "version": "1.0.1",
  "description": "Right-click any tab to set a custom title that persists for the lifetime of the tab.",
  "permissions": [
    "menus",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "anytitle@eloi.barti",
      "strict_min_version": "78.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
